{
  "name": "careerforge",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspace=@careerforge/shared-types && npm run build --workspace=@careerforge/api && npm run build --workspace=@careerforge/web",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "eslint": "^9.9.0"
  },
  "prisma": {
    "seed": "tsx apps/api/src/prisma/seed.ts"
  }
}
