# Server configuration
PORT=5000
NODE_ENV=development

# Database & Cache connection strings
# For local dev, PostgreSQL runs on port 5432, Redis on 6379
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/careerforge?schema=public"
REDIS_URL="redis://localhost:6379"

# Security secrets (Use high-entropy strings, e.g. run 'openssl rand -base64 32')
JWT_ACCESS_SECRET="your_jwt_access_secret_should_be_at_least_32_characters"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_should_be_at_least_32_characters"

# Frontend URL
FRONTEND_URL="http://localhost:3000"

# Third-party Integrations (Optional for local development, mandatory for production features)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

RESEND_API_KEY=""

# AI Provider Keys
OPENAI_API_KEY=""
GEMINI_API_KEY=""
